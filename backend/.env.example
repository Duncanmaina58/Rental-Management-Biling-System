# Copy this file to .env and fill in real values. Never commit .env itself.

NODE_ENV=development
PORT=4000

# Postgres connection string
DATABASE_URL="postgresql://rmbs_user:rmbs_password@localhost:5432/rmbs_dev?schema=public"

# Generate a strong random secret, e.g.: openssl rand -base64 48
JWT_SECRET="replace-with-a-long-random-string"
JWT_EXPIRES_IN="8h"

# Frontend origin allowed to call this API
CORS_ORIGIN="http://localhost:5173"
